      "sourceParagraph": 79
    },
    {
      "type": "paragraph",
      "runs": [
        {
          "text": "Some may feel uncomfortable. "
        }
      ],
      "sourceParagraph": 80
    },
    {
      "type": "paragraph",
      "runs": [
        {
          "text": "Some may feel like they were written from your own "
        }
