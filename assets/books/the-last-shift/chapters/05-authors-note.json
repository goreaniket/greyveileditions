    },
    {
      "type": "paragraph",
      "runs": [
        {
          "text": "experience life. "
        }
      ],
      "sourceParagraph": 78
    },
    {
      "type": "paragraph",
      "runs": [
        {
          "text": "Some chapters may feel familiar. "
        }
